              ],
              "inputs": [
                "default",
                "^production",
                {
                  "externalDependencies": [
                    "cypress"
                  ]
                }
              ],
              "cache": true,
              "options": {
                "cwd": "apps/frontend-e2e",
                "env": {
                  "TS_NODE_COMPILER_OPTIONS": "{\"customConditions\":null}"
